# Copy to ~/.ssh/config on each machine and adapt host blocks.
# This is a template — never commit the real one (it lives outside the repo).

Host *
    ServerAliveInterval 60
    ServerAliveCountMax 3
    # Pass TERM to the remote sshd; combined with ghostty's
    # shell-integration-features = ssh-terminfo it ensures helix/zellij render.
    SendEnv TERM
    # Forward the local ssh-agent so git on the remote uses your local keys.
    ForwardAgent yes

# Example: a remote host where dev-env is also deployed.
# `ssh workmachine` lands you straight inside the distrobox container.
# Host workmachine
#     HostName 10.0.0.42
#     User sergeik
#     RequestTTY force
#     RemoteCommand distrobox enter devenv

# Example: an ad-hoc VPS without dev-env. Plain ssh, ghostty's
# ssh-terminfo integration handles the terminfo on its own.
# Host vps-staging
#     HostName staging.example.com
#     User root
