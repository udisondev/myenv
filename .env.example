# Copy to .env (uncommitted) on each host so docker compose picks up correct
# UID/GID for bind-mounted files. Generate with:
#   echo "HOST_UID=$(id -u)\nHOST_GID=$(id -g)\nUSER=$(id -un)" > .env

HOST_UID=1000
HOST_GID=1000
USER=sergeik

# Public key to authorize for inbound SSH into the container.
# Override if your key isn't id_ed25519.pub.
#SSH_PUBKEY=~/.ssh/id_ed25519.pub
